<UserControl x:Class="VoxtralRealtime.Views.RecordingControlsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" BorderBrush="#E5E5EA" BorderThickness="0,0,0,0.5" Padding="8,4">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- Transcribe / Pause / Resume button -->
            <Button x:Name="MainBtn" Style="{StaticResource ToolbarButton}"
                    Click="OnMainAction" Padding="10,5" Margin="2,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="MainIcon" FontSize="12" Margin="0,0,5,0"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="MainLabel" FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Loading indicator -->
            <StackPanel x:Name="LoadingIndicator" Orientation="Horizontal" Margin="8,0"
                        Visibility="Collapsed">
                <ProgressBar IsIndeterminate="True" Width="16" Height="16"
                             Foreground="{StaticResource PrimaryBrush}" BorderThickness="0"/>
                <TextBlock Text="Loading..." FontSize="13" Margin="6,0,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Done button -->
            <Button x:Name="DoneBtn" Style="{StaticResource ToolbarButton}"
                    Click="OnDone" Padding="10,5" Margin="2,0" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2713;" FontSize="12" Margin="0,0,5,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Done" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Unload Model button -->
            <Button x:Name="UnloadBtn" Style="{StaticResource ToolbarButton}"
                    Click="OnUnload" Padding="10,5" Margin="2,0" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x23CF;" FontSize="12" Margin="0,0,5,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Unload Model" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
