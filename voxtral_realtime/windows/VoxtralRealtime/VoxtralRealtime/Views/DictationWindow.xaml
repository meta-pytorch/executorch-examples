<Window x:Class="VoxtralRealtime.Views.DictationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:VoxtralRealtime.Views"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowActivated="False" ShowInTaskbar="False"
        Width="320" SizeToContent="Height"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="14" Padding="16" Margin="4"
            Background="#E8FFFFFF" BorderBrush="#40000000" BorderThickness="0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>

        <StackPanel>
            <!-- Audio Level -->
            <views:AudioLevelControl x:Name="DictationLevel" Width="240" Height="30"
                                     HorizontalAlignment="Center" Margin="0,4,0,8"/>

            <!-- Dictation Text -->
            <TextBlock x:Name="DictationText" TextWrapping="Wrap" FontSize="14"
                       MaxHeight="200" Margin="0,0,0,8" Foreground="#333333"/>

            <!-- Status hint -->
            <TextBlock Text="Ctrl+Space to finish" FontSize="11"
                       Foreground="#88000000" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
