<UserControl x:Class="VoxtralRealtime.Views.SnippetManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VoxtralRealtime.Models">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Text Snippets" FontSize="22" FontWeight="SemiBold"/>
            <Button Content="+ Add" Style="{StaticResource ToolbarButton}"
                    HorizontalAlignment="Right" Click="OnAdd" Padding="12,6"/>
        </Grid>

        <!-- List -->
        <ListBox Grid.Row="1" x:Name="SnippetsList" BorderThickness="0"
                 ItemsSource="{Binding Entries}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:Snippet}">
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock FontSize="11" Foreground="Gray">
                                <Run Text="Trigger: &quot;"/>
                                <Run Text="{Binding Trigger, Mode=OneWay}"/>
                                <Run Text="&quot;"/>
                            </TextBlock>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Edit" Style="{StaticResource ToolbarButton}"
                                Click="OnEdit" Tag="{Binding}" Margin="4,0" FontSize="11"/>

                        <Button Grid.Column="3" Content="Delete" Style="{StaticResource ToolbarButton}"
                                Click="OnDelete" Tag="{Binding}" FontSize="11"
                                Foreground="{StaticResource ErrorBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
