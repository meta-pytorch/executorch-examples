<UserControl x:Class="VoxtralRealtime.Views.TranscriptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VoxtralRealtime.Views"
             Background="White">
    <Grid>
        <!-- Transcript scroll area -->
        <ScrollViewer x:Name="TranscriptScroller"
                      VerticalScrollBarVisibility="Auto" Padding="24,16,24,60">
            <StackPanel>
                <!-- Listening placeholder (centered, shown when live + empty) -->
                <StackPanel x:Name="ListeningPlaceholder" Visibility="Collapsed"
                            HorizontalAlignment="Center" Margin="0,80,0,0">
                    <views:AudioLevelControl x:Name="PlaceholderLevel"
                                             Width="160" Height="36"
                                             HorizontalAlignment="Center"/>
                    <TextBlock Text="Listening..." FontSize="16"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock x:Name="ListeningStatus" FontSize="11"
                               Foreground="{StaticResource LabelGrayBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Transcript text -->
                <TextBlock x:Name="TranscriptText" TextWrapping="Wrap" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           LineHeight="24" Padding="8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Copy All button (top-right overlay, shown when text exists) -->
        <Button x:Name="CopyBtn" Content="Copy All" Style="{StaticResource ActionButton}"
                Click="OnCopyAll" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,12,16,0" FontSize="11" Padding="10,5" Visibility="Collapsed"/>

        <!-- Bottom status capsule (centered at bottom, matches macOS .ultraThinMaterial) -->
        <Border x:Name="StatusCapsule" Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,14" CornerRadius="16" Padding="14,8">
            <Border.Background>
                <SolidColorBrush Color="#E8E8ED" Opacity="0.92"/>
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <!-- Paused icon -->
                <TextBlock x:Name="PausedIcon" Text="&#x23F8;" FontSize="11"
                           Foreground="{StaticResource WarningBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0" Visibility="Collapsed"/>
                <!-- Audio level bars (when transcribing) -->
                <views:AudioLevelControl x:Name="StatusLevel" Width="40" Height="16"
                                         Visibility="Collapsed"/>
                <!-- Status text -->
                <TextBlock x:Name="StatusText" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
