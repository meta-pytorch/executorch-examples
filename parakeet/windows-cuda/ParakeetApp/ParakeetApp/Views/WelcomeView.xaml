<UserControl x:Class="ParakeetApp.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ParakeetApp.Views"
             Background="White">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="560" Margin="40">

            <!-- Waveform icon -->
            <views:AudioLevelControl x:Name="WaveIcon" Width="80" Height="50"
                                     HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Title -->
            <TextBlock Text="Parakeet Speech-to-Text" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <!-- Subtitle -->
            <TextBlock Text="On-device speech transcription powered by ExecuTorch + CUDA"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <TextBlock Text="Record audio, then transcribe with NVIDIA Parakeet TDT 0.6B"
                       FontSize="12" Foreground="{StaticResource LabelGrayBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <!-- Spacer -->
            <Border Height="8"/>

            <!-- Model Status Section -->
            <Grid HorizontalAlignment="Center" Margin="0,0,0,24">
                <!-- State: Unloaded -->
                <Button x:Name="DownloadModelBtn" Style="{StaticResource ActionButton}"
                        Click="OnDownloadModel" Padding="20,10" FontSize="14"
                        Foreground="{StaticResource TextPrimaryBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Download Model" FontSize="14"/>
                    </StackPanel>
                </Button>

                <!-- State: Downloading -->
                <Border x:Name="DownloadingPanel" Visibility="Collapsed"
                        Background="#F2F2F7" CornerRadius="10" Padding="8" MinWidth="300">
                    <StackPanel HorizontalAlignment="Center" Margin="8">
                        <ProgressBar x:Name="DownloadProgressBar" Minimum="0" Maximum="100"
                                     Value="0" Height="6" Width="240"
                                     Margin="0,0,0,8" Foreground="{StaticResource PrimaryBrush}"
                                     Background="#E5E5EA" BorderThickness="0"/>
                        <TextBlock x:Name="DownloadStatusText" Text="Preparing download..."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   MaxWidth="280" Margin="0,0,0,8"/>
                        <Button x:Name="CancelDownloadBtn" Content="Cancel"
                                Style="{StaticResource ToolbarButton}"
                                Click="OnCancelDownload" HorizontalAlignment="Center"
                                Padding="12,4" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- State: Ready -->
                <StackPanel x:Name="ReadyPanel" Visibility="Collapsed"
                            Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{StaticResource SuccessColor}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Model ready" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Record Button (prominent, only when model ready) -->
            <Button x:Name="RecordBtn" Style="{StaticResource RecordButton}"
                    Click="OnStartRecording" HorizontalAlignment="Center"
                    Margin="0,0,0,24" MinWidth="180" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Fill="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Record" FontSize="15" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Shortcut Hints -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Margin="8,0">
                    <Border Background="#F2F2F7" CornerRadius="4" Padding="6,3"
                            HorizontalAlignment="Center">
                        <TextBlock Text="Ctrl+Shift+R" FontSize="10"
                                   FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <TextBlock Text="Record" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{StaticResource LabelGrayBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Margin="8,0">
                    <Border Background="#F2F2F7" CornerRadius="4" Padding="6,3"
                            HorizontalAlignment="Center">
                        <TextBlock Text="Ctrl+Enter" FontSize="10"
                                   FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <TextBlock Text="Stop &amp; Transcribe" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{StaticResource LabelGrayBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
