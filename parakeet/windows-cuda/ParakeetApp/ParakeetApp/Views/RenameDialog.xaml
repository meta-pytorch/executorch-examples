<Window x:Class="ParakeetApp.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Session" Width="360" Height="140"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <StackPanel Margin="16">
        <TextBlock Text="Title:" FontSize="13" Margin="0,0,0,6"/>
        <TextBox x:Name="TitleBox" FontSize="13" Padding="6,4"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="12,4" Margin="0,0,8,0" Click="OnCancel"
                    Style="{StaticResource ToolbarButton}"/>
            <Button Content="Save" Padding="12,4" Click="OnSave"
                    Style="{StaticResource PrimaryButton}" FontSize="13"/>
        </StackPanel>
    </StackPanel>
</Window>
