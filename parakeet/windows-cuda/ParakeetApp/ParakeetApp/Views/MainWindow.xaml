<Window x:Class="ParakeetApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ParakeetApp.Views"
        Title="Parakeet Speech-to-Text" Width="900" Height="600"
        MinWidth="600" MinHeight="400"
        Background="White"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <views:ErrorBannerControl VerticalAlignment="Top" Panel.ZIndex="100"
                                  Margin="80,0,80,0"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="180" MaxWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <views:SidebarView Grid.Column="0"/>
            <Rectangle Grid.Column="1" Width="0.5" Fill="#D1D1D6"
                       VerticalAlignment="Stretch"/>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <views:RecordingBar Grid.Row="0"/>
                <ContentControl Grid.Row="1" x:Name="DetailContent" Background="White"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
